<section class="mt-5">
    <h2>Available Books</h2>
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <img src="~/images/BookPic(1).jpg" class="card-img-top" alt="Book Picture">
                <div class="card-body">
                    <h5 class="card-title">Title: Engineering Change Management in Distruted Environment with PDM/PLM Support</h5>
                    <p class="card-text">Author: Joze Tavcar, Joze Duhovnik</p>
                    <a href="https://www.free-ebooks.net/engineering-textbooks/Engineering-Change-Management-in-Distruted-Environment-with-PDM-PLM-Support">Available Here</a>
                </div>
            </div>
        </div>
        <!-- Add more cards as needed -->
        <div class="col-md-4">
            <img src="~/images/BookPic(2).jpg" class="card-img-top" alt="Book Picture">
            <div class="card-body">
                <h5 class="card-title">Title: A First Course in Electrical and Computer Engineering</h5>
                <p class="card-text">Author:  Louis Scharf</p>
                <a href="https://www.free-ebooks.net/engineering/A-First-Course-in-Electrical-and-Computer-Engineering">Available Here</a>
            </div>
        </div>

        <div class="col-md-4">
            <img src="~/images/BookPic(3).jpg" class="card-img-top" alt="Book Picture">
            <div class="card-body">
                <h5 class="card-title">Title: 10 Great Ways to Self-Esteem</h5>
